<Window x:Class="Notifier.MessageSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="未读通知"
        Width="370"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid x:Name="RootGrid"
          Background="Transparent"
          MouseLeftButtonDown="RootGrid_MouseLeftButtonDown"
          MouseMove="RootGrid_MouseMove"
          MouseLeftButtonUp="RootGrid_MouseLeftButtonUp">
        <!-- 阴影层 -->
        <Border
                Background="Transparent"
                CornerRadius="14">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="30" RenderingBias="Quality"/>
            </Border.Effect>
        </Border>
        <!-- 实际窗口主体 -->
        <Border Background="#D7F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- 标题栏 -->
                <Grid Grid.Row="0"
                      x:Name="TitleBar"
                      Background="#E8E8E8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="📢"
                               FontSize="14"
                               Margin="14,10,6,10"/>
                    <TextBlock Grid.Column="1"
                               Text="未读通知"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Width="26"
                            Height="26"
                            Margin="6"/>
                </Grid>
                <!-- 消息列表 -->
                <ScrollViewer Grid.Row="1"
                              Margin="10"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MessageList"
                                  IsHitTestVisible="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Tag 绑定 Title 用于标识要删除的消息 -->
                                <Border CornerRadius="8"
                                        Background="#18000000"
                                        Padding="12,8"
                                        Margin="0,4"
                                        Tag="{Binding Title}"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="MessageItem_MouseLeftButtonDown">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#DD000000"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding Bodies}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="#AA000000"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="16,2,0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!-- 底部状态栏-->
                <Border Grid.Row="2"
                        Background="#E8E8E8"
                        CornerRadius="0,0,14,14"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatusText"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="11"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"/>
                        <!-- 清除消息按钮 -->
                        <Border Grid.Column="1"
                                Background="#D32F2F"
                                CornerRadius="6"
                                Cursor="Hand">
                            <Button x:Name="ClearButton"
                                    Content="清除消息"
                                    Click="ClearButton_Click"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="11"
                                    Padding="8,4"
                                    Cursor="Hand" Opacity="0.995" Background="#00000000" FontFamily="Microsoft YaHei"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
