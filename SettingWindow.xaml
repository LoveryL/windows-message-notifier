<Window x:Class="Notifier.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="控制中心"
        Width="370" Height="315"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- ==================== 动画 ==================== -->
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-420" To="0" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="-420" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.25"/>
        </Storyboard>


        <!-- ==================== 通用样式 ==================== -->
        <!-- 轨道背景 -->
        <Style x:Key="SliderBgButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2" Background="#30FFFFFF"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 轨道填充 -->
        <Style x:Key="SliderFillButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thumb 基础 -->
        <Style x:Key="SliderThumbBase" TargetType="Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Dot"
                                 Fill="{TemplateBinding Background}"
                                 Stroke="#FFFFFF" StrokeThickness="2">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="7" CenterY="7"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.18" ScaleY="1.18" CenterX="7" CenterY="7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ==================== 音量 Slider ==================== -->
        <ControlTemplate x:Key="VolumeSliderTemplate" TargetType="Slider">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Background="#4A90D9" Style="{StaticResource SliderFillButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderBgButton}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Background="#4A90D9" Style="{StaticResource SliderThumbBase}"/>
                </Track.Thumb>
            </Track>
        </ControlTemplate>

        <!-- ==================== 亮度 Slider ==================== -->
        <ControlTemplate x:Key="BrightnessSliderTemplate" TargetType="Slider">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Background="#F5A623" Style="{StaticResource SliderFillButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderBgButton}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Background="#F5A623" Style="{StaticResource SliderThumbBase}"/>
                </Track.Thumb>
            </Track>
        </ControlTemplate>


        <!-- ==================== 圆形媒体按钮 ==================== -->
        <Style x:Key="CircleMediaBtn" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <!-- ==================== 主体 UI ==================== -->
    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform X="-420"/>
        </Grid.RenderTransform>

        <Border CornerRadius="14"
                Background="#EFF6F6F6"
                BorderBrush="#22000000"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Background="#E2E2E2" CornerRadius="14,14,0,0" Padding="14,10">
                    <TextBlock Text="控制中心" FontWeight="SemiBold" FontSize="13" Foreground="#222"/>
                </Border>

                <!-- 中间：音量与亮度 -->
                <StackPanel Grid.Row="1" Margin="22,20,22,10" VerticalAlignment="Center">
                    <!-- 音量 -->
                    <DockPanel Margin="0,0,0,20">
                        <TextBlock Text="🔊" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="音量" FontSize="12" Foreground="#555" Width="34" VerticalAlignment="Center"/>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="50"
                                Template="{StaticResource VolumeSliderTemplate}"
                                IsSnapToTickEnabled="False"
                                Margin="8,0,0,0"/>
                    </DockPanel>

                    <!-- 亮度 -->
                    <DockPanel>
                        <TextBlock Text="☀️" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="亮度" FontSize="12" Foreground="#555" Width="34" VerticalAlignment="Center"/>
                        <Slider x:Name="BrightnessSlider"
                                Minimum="0" Maximum="100" Value="70"
                                Template="{StaticResource BrightnessSliderTemplate}"
                                IsSnapToTickEnabled="False"
                                Margin="8,0,0,0"/>
                    </DockPanel>
                </StackPanel>

                <!-- 底部：媒体控制 -->
                <Border Grid.Row="2" Background="#E2E2E2" CornerRadius="0,0,14,14" Padding="0,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnPrevious"
                                Style="{StaticResource CircleMediaBtn}"
                                ToolTip="上一首">
                            <TextBlock Text="⏮" FontSize="18"/>
                        </Button>

                        <Button x:Name="BtnPlayPause"
                                Style="{StaticResource CircleMediaBtn}"
                                Margin="26,0"
                                ToolTip="暂停 / 播放">
                            <TextBlock x:Name="PlayPauseIcon" Text="⏸" FontSize="20"/>
                        </Button>

                        <Button x:Name="BtnNext"
                                Style="{StaticResource CircleMediaBtn}"
                                ToolTip="下一首">
                            <TextBlock Text="⏭" FontSize="18"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>